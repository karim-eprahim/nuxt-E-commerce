      "text": "declare module \"#auth-utils\" {\n    interface User {\n        id: string;\n        email: string;\n        role: 'USER' | 'ADMIN';\n        name: string;\n        avatarUrl: string | null;\n    }\n\n    interface UserSession {\n        // Add your own fields\n    }\n\n    interface SecureSessionData {\n        // Add your own fields\n  }\n}",
