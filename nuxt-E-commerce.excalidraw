      "isDeleted": false,
      "boundElements": [],
      "updated": 1772460690420,
      "link": null,
      "locked": false,
      "text": "export default defineEventHandler(async (event) => {\n  await requireUserSession(event);\n  const session = await getUserSession(event);\n  // Only ADMIN can update categories\n  if (session.user?.role !== \"ADMIN\") {\n    throw createError({\n      statusCode: 401,\n      statusMessage: \"Unauthorized\",\n    });\n  }\n  const { name } = await readValidatedBody(event, (body) =>\n    categorySchema.parse(body),\n  );\n  const categoryId = event.context.params?.categoryId;\n  const category = await db.category.update({\n    where: {\n      id: categoryId,\n    },\n    data: {\n      name,\n    },\n  });\n  return category;\n});\n",
      "fontSize": 13.518880433120067,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "export default defineEventHandler(async (event) => {\n  await requireUserSession(event);\n  const session = await getUserSession(event);\n  // Only ADMIN can update categories\n  if (session.user?.role !== \"ADMIN\") {\n    throw createError({\n      statusCode: 401,\n      statusMessage: \"Unauthorized\",\n    });\n  }\n  const { name } = await readValidatedBody(event, (body) =>\n    categorySchema.parse(body),\n  );\n  const categoryId = event.context.params?.categoryId;\n  const category = await db.category.update({\n    where: {\n      id: categoryId,\n    },\n    data: {\n      name,\n    },\n  });\n  return category;\n});\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
