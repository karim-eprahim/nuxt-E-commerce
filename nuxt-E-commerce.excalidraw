    {
      "id": "3Ppn-V1_XIraCbWLuRun7",
      "type": "text",
      "x": 4296.005516548953,
      "y": 5881.893692984167,
      "width": 440.5326944986972,
      "height": 20,
      "angle": 0,
      "strokeColor": "#f08c00",
