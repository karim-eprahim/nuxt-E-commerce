      "updated": 1771977354235,
      "link": null,
      "locked": false,
      "text": "const formSchema = toTypedSchema(categorySchema);",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "right",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "const formSchema = toTypedSchema(categorySchema);",
