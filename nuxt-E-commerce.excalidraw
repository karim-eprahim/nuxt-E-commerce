      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bKv",
      "roundness": null,
      "seed": 1275617289,
      "version": 108,
      "versionNonce": 74871785,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771720517660,
      "link": null,
      "locked": false,
      "text": "export default defineNuxtRouteMiddleware(async(to, from) => {\n    const { user } = useUserSession();\n    if (!user.value) {\n        return navigateTo(\"/auth/login\");\n    }\n    if (user.value && user.value.role !== \"ADMIN\") {\n        return navigateTo(\"/\");\n    }\n})",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "kGAncY2pHLOemYyvsd--e",
      "originalText": "export default defineNuxtRouteMiddleware(async(to, from) => {\n    const { user } = useUserSession();\n    if (!user.value) {\n        return navigateTo(\"/auth/login\");\n    }\n    if (user.value && user.value.role !== \"ADMIN\") {\n        return navigateTo(\"/\");\n    }\n})",
      "autoResize": true,
      "lineHeight": 1.25
    },
