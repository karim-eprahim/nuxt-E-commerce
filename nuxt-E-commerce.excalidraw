      "seed": 1879033967,
      "version": 70,
      "versionNonce": 1036573391,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771977416642,
      "link": null,
      "locked": false,
      "text": "const form = useForm({\n  validationSchema: formSchema,\n  initialValues: currentCategory.value || {\n    name: \"\",\n  },\n});",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
