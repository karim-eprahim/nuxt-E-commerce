      "link": null,
      "locked": false,
      "text": "    import \"dotenv/config\";\n    import { defineConfig } from \"prisma/config\";\n    \n    export default defineConfig({\n      schema: \"prisma/schema.prisma\",\n      migrations: {\n        path: \"prisma/migrations\",\n      },\n      datasource: {\n        url: process.env[\"DATABASE_URL\"],\n      },\n    });\n    ",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "7Dg7tH7z8OKabZxqXNirx",
      "originalText": "    import \"dotenv/config\";\n    import { defineConfig } from \"prisma/config\";\n    \n    export default defineConfig({\n      schema: \"prisma/schema.prisma\",\n      migrations: {\n        path: \"prisma/migrations\",\n      },\n      datasource: {\n        url: process.env[\"DATABASE_URL\"],\n      },\n    });\n    ",
      "autoResize": true,
      "lineHeight": 1.25
    },
