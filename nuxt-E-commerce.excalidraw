    {
      "id": "43UYI1rbURpJ9b0VJMH43",
      "type": "text",
      "x": 4212.47256187136,
      "y": 3749.4178567993263,
      "width": 536.7992553710938,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
