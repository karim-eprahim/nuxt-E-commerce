    {
      "id": "lCNCyxQsIWkkmzKhAYLJo",
      "type": "text",
      "x": 4331.453749353521,
      "y": 8014.539148624071,
      "width": 367.05279541015625,
      "height": 422.46501353500213,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "#b2f2bb",
