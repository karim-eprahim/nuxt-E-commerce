    {
      "id": "KCv7ThJbpuZDCtmnAZRuD",
      "type": "text",
      "x": 4277.510498180278,
      "y": 6596.376037354208,
      "width": 380.6212158203125,
      "height": 284.5714460100445,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bOf",
      "roundness": null,
      "seed": 1958187881,
      "version": 139,
      "versionNonce": 2116783113,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772244372962,
      "link": null,
      "locked": false,
      "text": "export default defineEventHandler(async (event) => {\n  await requireUserSession(event);\n  const session = await getUserSession(event);\n  console.log(session);\n  if (session.user && session.user?.role == \"ADMIN\") {\n    const { name } = await readValidatedBody(event, (body) =>\n      categorySchema.parse(body),\n    );\n    const category = await db.category.create({\n      data: {\n        name,\n        userId:session.user.id\n      },\n    });\n    return category\n  } else {\n    throw createError({\n      statusCode: 401,\n      statusMessage:\n        \"Unauthorized, You don't have permission to perform this action\",\n    });\n  }\n  return null;\n});",
      "fontSize": 9.485714867001482,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "export default defineEventHandler(async (event) => {\n  await requireUserSession(event);\n  const session = await getUserSession(event);\n  console.log(session);\n  if (session.user && session.user?.role == \"ADMIN\") {\n    const { name } = await readValidatedBody(event, (body) =>\n      categorySchema.parse(body),\n    );\n    const category = await db.category.create({\n      data: {\n        name,\n        userId:session.user.id\n      },\n    });\n    return category\n  } else {\n    throw createError({\n      statusCode: 401,\n      statusMessage:\n        \"Unauthorized, You don't have permission to perform this action\",\n    });\n  }\n  return null;\n});",
      "autoResize": true,
      "lineHeight": 1.25
    },
